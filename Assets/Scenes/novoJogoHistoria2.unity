  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Ent\xE3o, pouco a pouco, a tranquilidade desapareceu.\r\nUma sombra tomou
    conta do castelo e se espalhou pelos caminhos do reino.\r\nAs vilas mudaram,
    os rostos se calaram, e o que antes parecia seguro passou a carregar sil\xEAncio
    e medo.\r\nHist\xF3rias come\xE7aram a circular entre os poucos que restaram:
    falavam de magia, de um poder sombrio e de algo importante que havia sido perdido.\r\nEnquanto
    muitos se escondiam, Clarke ergueu o olhar.\r\nE naquele instante sentiu que
    sua jornada estava apenas come\xE7ando.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: e8b1cd4cd2e762432af6bac6bff73d08, type: 2}
